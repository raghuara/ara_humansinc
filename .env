# ── Local network (LAN) dev server ──────────────────────────────────────────
# Bind to all network interfaces so teammates on the same network can open the
# app at http://<your-ip>:3000  (e.g. http://192.168.1.30:3000)
HOST=0.0.0.0
PORT=3000

# Allow the app to be opened via an IP / hostname (not just localhost)
DANGEROUSLY_DISABLE_HOST_CHECK=true

# Don't auto-open a browser tab on the host machine
BROWSER=none

# Note: hot-reload (HMR) from other machines works automatically — the browser
# connects its live-reload socket back to whatever host it loaded the page from.
